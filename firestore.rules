rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions to check user roles and permissions.
    function isSuperAdmin() {
      // Check if the requesting user is a superadmin.
      return get(/databases/$(database)/documents/admin_users/$(request.auth.uid)).data.role == 'superadmin';
    }

    function isModerator() {
        // Check if the user has moderator or superadmin role.
        let userDoc = get(/databases/$(database)/documents/admin_users/$(request.auth.uid));
        return userDoc.data.role == 'moderator' || isSuperAdmin();
    }
    
    function hasPermission(permission) {
       // Check if the user has a specific permission. Superadmins have all permissions.
       let userDoc = get(/databases/$(database)/documents/admin_users/$(request.auth.uid));
       return isSuperAdmin() || permission in userDoc.data.permissions;
    }

    function isSignedIn() {
      // Check if the user is signed in.
      return request.auth != null;
    }

    function isOwner(userId) {
      // Check if the requesting user is the owner of the document.
      return request.auth.uid == userId;
    }

    // Publicly readable collections
    match /products/{productId} {
      allow read: if true;
      allow write: if hasPermission('manage_products');
    }
    
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if hasPermission('manage_categories');
    }

    match /brands/{brandId} {
      allow read: if true;
      allow write: if hasPermission('manage_brands');
    }
    
    match /site_config/main {
      allow read: if true;
      // Allow writing to site config if user has any of the appearance-related permissions
      allow write: if hasPermission('manage_appearance') || hasPermission('manage_plugins') || hasPermission('manage_payments') || hasPermission('manage_tax_settings') || hasPermission('manage_integrations') || hasPermission('manage_loyalty_program');
    }
    
    match /pages/{pageSlug} {
      allow read: if true;
      allow write: if hasPermission('manage_pages');
    }

    // User-specific data
    match /users/{userId} {
      allow read: if isOwner(userId) || isModerator();
      allow create: if isSignedIn(); // Anyone signed in can create their own profile
      allow update: if isOwner(userId) || hasPermission('manage_customers');
      allow delete: if isSuperAdmin(); // Only super admins can delete user profiles
    }
    
    match /orders/{orderId} {
      allow read, update: if isOwner(get(/databases/$(database)/documents/orders/$(orderId)).data.customer.id) || hasPermission('manage_orders');
      allow create: if isSignedIn(); // Users can create their own orders during checkout
    }

    match /notifications/{notificationId} {
        allow read, write: if isOwner(resource.data.userId);
    }
    
    match /stockNotifications/{notificationId} {
        allow read: if hasPermission('manage_products');
        allow create: if true; // Anyone can request a stock notification
        allow update: if hasPermission('manage_products'); // Only admins can update the 'notified' status
    }

    // CMS-specific collections
    match /admin_users/{userId} {
        allow read, write: if hasPermission('manage_moderators');
    }

    match /discounts/{discountId} {
        allow read: if true; // Allow reading for discount application
        allow write: if hasPermission('manage_discounts');
    }
    
    match /email_campaigns/{campaignId} {
        allow read, write: if hasPermission('manage_email_campaigns');
    }
    
    match /tax_rates/{rateId} {
        allow read: if true;
        allow write: if hasPermission('manage_tax_settings');
    }
    
    match /counters/{counterName} {
        // Allow server-side processes (like placing an order) to update counters
        allow write: if true; 
        allow read: if hasPermission('manage_orders');
    }
  }
}
