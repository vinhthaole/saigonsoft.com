rules_version = '2';

// Chỉ cho phép người dùng đã đăng nhập đọc và ghi vào tài khoản của họ.
// Các tệp công khai có thể được đọc bởi bất kỳ ai.
service firebase.storage {
  match /b/{bucket}/o {
    // Chỉ cho phép đọc public và quản trị viên viết vào những folder chỉ định
    match /{folder}/{allPaths=**} {
      allow read: if folder in ['product_images', 'site_assets', 'company_assets', 'page-content'];
      allow write: if folder in ['product_images', 'site_assets', 'company_assets', 'page-content'] && request.auth != null;
    }
    
    // Fallback cho folder cấp 1 nếu ai đó up thẳng vào root
    match /{folder} {
      allow read: if folder in ['product_images', 'site_assets', 'company_assets', 'page-content'];
      allow write: if folder in ['product_images', 'site_assets', 'company_assets', 'page-content'] && request.auth != null;
    }
  }
}
